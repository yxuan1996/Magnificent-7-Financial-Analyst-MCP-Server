# =============================================================================
# Supabase Auth
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# =============================================================================
# Permit.io  (authorization — what may you do?)
# =============================================================================
# API key from app.permit.io → Settings → API Keys
PERMIT_API_KEY=permit_key_...

# URL of the Permit PDP (Policy Decision Point).
# For local dev, run the PDP sidecar:
#   docker run -p 7766:7000 --env PDP_API_KEY=<your-key> permitio/pdp-v2:latest
# For production, use the cloud PDP:
#   PERMIT_PDP_URL=https://cloudpdp.api.permit.io
PERMIT_PDP_URL=http://localhost:7766

# =============================================================================
# Pinecone Vector DB
# =============================================================================
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=mag7-annual-reports

# =============================================================================
# Neo4j Graph DB
# =============================================================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=neo4j

# =============================================================================
# MCP Server
# =============================================================================
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8000
MCP_SERVER_NAME=mag7-financial-analyst
MCP_LOG_LEVEL=INFO
